generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  STAFF
}

enum TransactionType {
  INVESTMENT
  INCOME
  EXPENSE
  WITHDRAWAL
}

enum ExpenseScope {
  COMPANY
  CLIENT
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  ESEWA
  KHALTI
  CONNECT_IPS
  CARD
  OTHER
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String
  role     Role    @default(STAFF)
  isActive Boolean @default(true)

  transactions    Transaction[]
  createdClients  Client[]      @relation("ClientCreatedBy")
  createdProjects Project[]     @relation("ProjectCreatedBy")
  activityLogs    ActivityLog[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Category {
  id          String          @id @default(cuid())
  name        String
  type        TransactionType
  description String?
  isDefault   Boolean         @default(false)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, type])
}

model Client {
  id           String  @id @default(cuid())
  name         String
  companyName  String?
  email        String?
  phone        String?
  address      String?
  status       String  @default("active")
  logoUrl      String?
  coverTheme   String? @default("auto")
  website      String?
  facebookUrl  String?
  instagramUrl String?
  tiktokUrl    String?
  linkedinUrl  String?
  youtubeUrl   String?
  industry     String?
  notes        String? @db.Text

  projects     Project[]
  transactions Transaction[]

  createdById String?
  createdBy   User?   @relation("ClientCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id        String        @id @default(cuid())
  name      String
  budget    Decimal?      @db.Decimal(12, 2)
  startDate DateTime?
  endDate   DateTime?
  status    ProjectStatus @default(ACTIVE)

  transactions Transaction[]

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?    @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Transaction {
  id            String                  @id @default(cuid())
  type          TransactionType
  title         String
  amount        Decimal                 @db.Decimal(12, 2)
  date          DateTime
  paymentMethod PaymentMethod           @default(BANK_TRANSFER)
  notes         String?
  attachments   TransactionAttachment[]
  expenseScope  ExpenseScope?
  paidBy        String?
  doneFor       String?
  isBillable    Boolean                 @default(false)
  isReimbursed  Boolean                 @default(false)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransactionAttachment {
  id             String  @id @default(cuid())
  fileName       String
  fileUrl        String
  fileType       String?
  fileSize       Int?
  attachmentType String  @default("RECEIPT")

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  uploadedAt DateTime @default(now())
}

model ActivityLog {
  id       String  @id @default(cuid())
  action   String
  entity   String
  entityId String?
  message  String
  metadata Json?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entity])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
}
