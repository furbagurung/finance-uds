generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  STAFF
  EMPLOYEE
}

enum TransactionType {
  INVESTMENT
  INCOME
  EXPENSE
  WITHDRAWAL
}

enum ExpenseScope {
  COMPANY
  CLIENT
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  ESEWA
  KHALTI
  CONNECT_IPS
  CARD
  OTHER
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum ProjectType {
  MONTHLY_RETAINER
  ONE_TIME
  ONGOING
  INTERNAL
}

enum BillingCycle {
  NONE
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  RESIGNED
}

enum SalaryType {
  MONTHLY
  HOURLY
  CONTRACT
}

enum PayrollStatus {
  DRAFT
  PAID
  CANCELLED
}

enum CalendarSystem {
  AD
  BS
}

enum FiscalYearType {
  CALENDAR_YEAR
  INDIA_AD_FY
  NEPAL_BS_FY
}

model Branch {
  id             String         @id @default(cuid())
  name           String
  code           String         @unique
  country        String
  currency       String
  calendarSystem CalendarSystem
  fiscalYearType FiscalYearType
  isActive       Boolean        @default(true)

  users          User[]
  employees      Employee[]
  clients        Client[]
  projects       Project[]
  transactions   Transaction[]
  payrollRecords PayrollRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String
  role     Role    @default(STAFF)
  isActive Boolean @default(true)

  employeeProfile Employee?

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  transactions    Transaction[]
  createdClients  Client[]      @relation("ClientCreatedBy")
  createdProjects Project[]     @relation("ProjectCreatedBy")
  activityLogs    ActivityLog[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Employee {
  id           String         @id @default(cuid())
  fullName     String
  email        String         @unique
  phone        String?
  position     String?
  department   String?
  joiningDate  DateTime?
  salaryAmount Decimal?       @db.Decimal(12, 2)
  salaryType   SalaryType     @default(MONTHLY)
  status       EmployeeStatus @default(ACTIVE)
  notes        String?        @db.Text

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  payrollRecords PayrollRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([department])
}

model PayrollRecord {
  id            String        @id @default(cuid())
  month         Int
  year          Int
  basicSalary   Decimal       @db.Decimal(12, 2)
  bonus         Decimal       @default(0) @db.Decimal(12, 2)
  deduction     Decimal       @default(0) @db.Decimal(12, 2)
  netPay        Decimal       @db.Decimal(12, 2)
  paymentDate   DateTime?
  paymentMethod PaymentMethod @default(BANK_TRANSFER)
  status        PayrollStatus @default(DRAFT)
  currency      String?
  notes         String?       @db.Text

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, month, year])
  @@index([status])
  @@index([year, month])
}

model Category {
  id          String          @id @default(cuid())
  name        String
  type        TransactionType
  description String?
  isDefault   Boolean         @default(false)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, type])
}

model Client {
  id           String  @id @default(cuid())
  name         String
  companyName  String?
  email        String?
  phone        String?
  address      String?
  status       String  @default("active")
  logoUrl      String?
  coverTheme   String? @default("auto")
  website      String?
  facebookUrl  String?
  instagramUrl String?
  tiktokUrl    String?
  linkedinUrl  String?
  youtubeUrl   String?
  industry     String?
  notes        String? @db.Text

  projects     Project[]
  transactions Transaction[]

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  createdById String?
  createdBy   User?   @relation("ClientCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id                    String        @id @default(cuid())
  name                  String
  budget                Decimal?      @db.Decimal(12, 2)
  startDate             DateTime?
  endDate               DateTime?
  status                ProjectStatus @default(ACTIVE)
  projectType           ProjectType   @default(ONE_TIME)
  billingCycle          BillingCycle  @default(ONE_TIME)
  monthlyRetainerAmount Decimal?      @db.Decimal(12, 2)
  projectValue          Decimal?      @db.Decimal(12, 2)
  currency              String?
  billingStartDate      DateTime?
  billingEndDate        DateTime?
  nextBillingDate       DateTime?

  transactions Transaction[]

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?    @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Transaction {
  id            String                  @id @default(cuid())
  type          TransactionType
  title         String
  amount        Decimal                 @db.Decimal(12, 2)
  date          DateTime
  currency      String?
  paymentMethod PaymentMethod           @default(BANK_TRANSFER)
  notes         String?
  attachments   TransactionAttachment[]
  expenseScope  ExpenseScope?
  paidBy        String?
  doneFor       String?
  isBillable    Boolean                 @default(false)
  isReimbursed  Boolean                 @default(false)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  payrollRecord PayrollRecord?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransactionAttachment {
  id             String  @id @default(cuid())
  fileName       String
  fileUrl        String
  fileType       String?
  fileSize       Int?
  attachmentType String  @default("RECEIPT")

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  uploadedAt DateTime @default(now())
}

model ActivityLog {
  id       String  @id @default(cuid())
  action   String
  entity   String
  entityId String?
  message  String
  metadata Json?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entity])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
}
